# Copy to .env locally (gitignored). In cloud triggers/routines, set these as the
# routine's environment variables instead — do NOT create a .env in the cloud.

# Perplexity — RETIRED/optional. Research now runs on the agent's native web search; no routine
# needs this key. Leave both blank (or omit entirely); set only if you want the optional wrapper.
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Telegram (notifications) — scripts/notify.sh sends via the Bot API.
# Create a bot with @BotFather to get the token; get the chat ID from getUpdates
# after you message the bot once (see docs/VM-DEPLOYMENT.md §8).
TELEGRAM_BOT_TOKEN=your_bot_token_here       # e.g. 123456789:AA...
TELEGRAM_CHAT_ID=your_chat_id_here           # your numeric chat ID
# Optional: label the sender when multiple agents share one chat.
NOTIFY_SOURCE=trading-agent

# NOTE: Robinhood is NOT here. It's an MCP connector attached to the session/routine,
# authenticated through Claude — not via env vars.
