# Copy to .env locally (gitignored). In cloud triggers/routines, set these as the
# routine's environment variables instead — do NOT create a .env in the cloud.

# Perplexity (research) — optional; agent falls back to native web search if unset
PERPLEXITY_API_KEY=your_key_here
PERPLEXITY_MODEL=sonar

# Twilio WhatsApp (notifications)
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number
WHATSAPP_TO=whatsapp:+1XXXXXXXXXX            # your verified WhatsApp number

